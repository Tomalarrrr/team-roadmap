{
  "rules": {
    "roadmap": {
      ".read": true,
      ".write": true,
      "projects": {
        "$projectId": {
          ".validate": "newData.hasChildren(['id', 'title', 'owner', 'startDate', 'endDate', 'statusColor'])",
          "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
          "owner": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "startDate": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" },
          "endDate": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" },
          "statusColor": { ".validate": "newData.isString() && newData.val().matches(/^#[0-9A-Fa-f]{6}$/)" },
          "milestones": {
            "$milestoneId": {
              ".validate": "newData.hasChildren(['id', 'title', 'startDate', 'endDate', 'statusColor'])",
              "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
              "title": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 200" },
              "description": { ".validate": "newData.isString() && newData.val().length <= 1000" },
              "startDate": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" },
              "endDate": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" },
              "statusColor": { ".validate": "newData.isString() && newData.val().matches(/^#[0-9A-Fa-f]{6}$/)" },
              "tags": {
                ".validate": true,
                "$tag": { ".validate": "newData.isString() && newData.val().length <= 50" }
              },
              "$other": { ".validate": false }
            }
          },
          "dependencies": { ".validate": true },
          "$other": { ".validate": false }
        }
      },
      "teamMembers": {
        "$memberId": {
          ".validate": "newData.hasChildren(['id', 'name'])",
          "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "jobTitle": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "nameColor": { ".validate": "newData.isString() && newData.val().matches(/^#[0-9A-Fa-f]{6}$/)" },
          "order": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 200" },
          "$other": { ".validate": false }
        }
      },
      "dependencies": {
        "$depId": {
          ".validate": "newData.hasChildren(['id', 'fromProjectId', 'toProjectId', 'type'])",
          "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "fromProjectId": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "fromMilestoneId": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "toProjectId": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "toMilestoneId": { ".validate": "newData.isString() && newData.val().length <= 100" },
          "type": { ".validate": "newData.isString() && (newData.val() == 'finish-to-start' || newData.val() == 'start-to-start' || newData.val() == 'finish-to-finish')" },
          "waypoints": {
            ".validate": true,
            "$wp": {
              ".validate": "newData.hasChildren(['x', 'y'])",
              "x": { ".validate": "newData.isNumber()" },
              "y": { ".validate": "newData.isNumber()" },
              "$other": { ".validate": false }
            }
          },
          "$other": { ".validate": false }
        }
      },
      "leaveBlocks": {
        "$leaveId": {
          ".validate": "newData.hasChildren(['id', 'memberId', 'startDate', 'endDate', 'coverage', 'type'])",
          "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "memberId": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "startDate": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" },
          "endDate": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" },
          "coverage": { ".validate": "newData.isString() && (newData.val() == 'quarter' || newData.val() == 'half' || newData.val() == 'full')" },
          "type": { ".validate": "newData.isString() && (newData.val() == 'annual-leave' || newData.val() == 'training' || newData.val() == 'conference' || newData.val() == 'other')" },
          "label": { ".validate": "newData.isString() && newData.val().length <= 200" },
          "$other": { ".validate": false }
        }
      },
      "periodMarkers": {
        "$markerId": {
          ".validate": "newData.hasChildren(['id', 'startDate', 'endDate', 'color'])",
          "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
          "startDate": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" },
          "endDate": { ".validate": "newData.isString() && newData.val().matches(/^\\d{4}-\\d{2}-\\d{2}$/)" },
          "color": { ".validate": "newData.isString() && (newData.val() == 'grey' || newData.val() == 'yellow' || newData.val() == 'orange' || newData.val() == 'red' || newData.val() == 'green')" },
          "label": { ".validate": "newData.isString() && newData.val().length <= 200" },
          "$other": { ".validate": false }
        }
      },
      "$other": { ".validate": false }
    },

    "presence": {
      ".read": true,
      "$sessionId": {
        ".write": true,
        ".validate": "newData.hasChildren(['id', 'name', 'color', 'lastSeen'])",
        "id": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "name": { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "color": { ".validate": "newData.isString() && newData.val().matches(/^#[0-9A-Fa-f]{6}$/)" },
        "lastSeen": { ".validate": "newData.isNumber()" },
        "editingProjectId": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "$other": { ".validate": false }
      }
    },

    "connectFour": {
      ".read": true,
      "$gameCode": {
        ".write": true,
        ".validate": "newData.hasChildren(['board', 'currentTurn', 'players', 'createdAt'])",
        "board": {
          ".validate": "newData.isString() && newData.val().length == 48 && newData.val().matches(/^[.RY]+$/)"
        },
        "currentTurn": {
          ".validate": "newData.isString() && (newData.val() == 'red' || newData.val() == 'yellow')"
        },
        "players": {
          "red": {
            ".validate": "newData.hasChildren(['sessionId', 'name'])",
            "sessionId": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "name": { ".validate": "newData.isString() && newData.val().length <= 50" },
            "$other": { ".validate": false }
          },
          "yellow": {
            ".validate": "newData.hasChildren(['sessionId', 'name'])",
            "sessionId": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "name": { ".validate": "newData.isString() && newData.val().length <= 50" },
            "$other": { ".validate": false }
          },
          "$other": { ".validate": false }
        },
        "createdAt": { ".validate": "newData.isNumber()" },
        "winner": { ".validate": "newData.isString() && (newData.val() == 'red' || newData.val() == 'yellow' || newData.val() == 'draw')" },
        "winningCells": { ".validate": "newData.isString() && newData.val().length <= 100" },
        "startingColor": { ".validate": "newData.isString() && (newData.val() == 'red' || newData.val() == 'yellow')" },
        "turnStartedAt": { ".validate": "newData.isNumber()" },
        "$other": { ".validate": false }
      }
    },

    "ludo": {
      ".read": true,
      "$gameCode": {
        ".write": true,
        ".validate": "newData.hasChildren(['players', 'tokens', 'currentTurn', 'createdAt', 'playerCount']) && newData.child('playerCount').val() >= 1 && newData.child('playerCount').val() <= 4 && newData.child('tokens').val().length == 48",
        "tokens": {
          ".validate": "newData.isString() && newData.val().length == 48 && newData.val().matches(/^(bas|t[0-9]{2}|f[0-9]{2})+$/)"
        },
        "currentTurn": {
          ".validate": "newData.isString() && (newData.val() == 'red' || newData.val() == 'green' || newData.val() == 'yellow' || newData.val() == 'blue')"
        },
        "turnPhase": {
          ".validate": "newData.isString() && (newData.val() == 'roll' || newData.val() == 'move')"
        },
        "diceValue": {
          ".validate": "!newData.exists() || newData.val() === null || (newData.isNumber() && newData.val() >= 1 && newData.val() <= 12)"
        },
        "consecutiveSixes": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 3"
        },
        "winner": {
          ".validate": "!newData.exists() || newData.val() === null || (newData.isString() && (newData.val() == 'red' || newData.val() == 'green' || newData.val() == 'yellow' || newData.val() == 'blue'))"
        },
        "playerCount": { ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 4" },
        "createdAt": { ".validate": "newData.isNumber()" },
        "turnStartedAt": { ".validate": "newData.isNumber()" },
        "startedAt": { ".validate": "!newData.exists() || newData.val() === null || newData.isNumber()" },
        "finishOrder": { ".validate": "newData.isString() && newData.val().length <= 50" },
        "singlePlayer": { ".validate": "newData.isBoolean()" },
        "paused": { ".validate": "newData.isBoolean()" },
        "pausedAt": { ".validate": "!newData.exists() || newData.val() === null || newData.isNumber()" },
        "players": {
          ".validate": "newData.hasChild('red')",
          "$color": {
            ".validate": "newData.hasChildren(['sessionId', 'name'])",
            "sessionId": { ".validate": "newData.isString() && newData.val().length <= 100" },
            "name": { ".validate": "newData.isString() && newData.val().length <= 50" },
            "$other": { ".validate": false }
          }
        },
        "powerUpsEnabled": { ".validate": "newData.isBoolean()" },
        "powerUps": {
          ".validate": "newData.isString() && newData.val().length >= 8 && newData.val().length <= 500 && newData.val().matches(/^[A-Z_]{8,}$/)"
        },
        "boardEffects": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "activeBuffs": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "coins": {
          ".validate": "newData.isString() && newData.val().matches(/^[0-9,:]+$/) && newData.val().length <= 20"
        },
        "mysteryBoxes": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "flag": {
          ".validate": "newData.isString() && newData.val().length <= 30"
        },
        "rollStats": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "$other": { ".validate": false }
      }
    },

    "gamePaused": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isBoolean()"
    },

    ".read": false,
    ".write": false
  }
}

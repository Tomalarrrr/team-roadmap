# Firebase Configuration
# Get these values from your Firebase Console:
# https://console.firebase.google.com/ > Project Settings > General > Your apps > Web app

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# Server-side variable used by the Vercel API proxy in /api/db/[...path].ts.
# This routes the browser's roadmap reads/writes through Vercel so that
# corporate VPNs/proxies (which block firebasedatabase.app directly) never
# see Firebase traffic. Set this to the same value as VITE_FIREBASE_DATABASE_URL
# in Vercel project settings (Settings → Environment Variables).
# If unset, the proxy falls back to reading VITE_FIREBASE_DATABASE_URL at runtime.
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
